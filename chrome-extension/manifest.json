{
  "manifest_version": 3,
  "name": "Claw Agent",
  "version": "3.5.0",
  "description": "AI browser agent powered by NVIDIA NIM models",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Claw Agent",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; connect-src https://integrate.api.nvidia.com"
  }
}
