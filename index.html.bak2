<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>Claw AI</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}

:root,[data-theme="light"]{
  --bg:#f7f7f5;
  --bg-alt:#eae8e4;
  --surface:#ffffff;
  --surface-hover:#f5f4f2;
  --border:#e5e3df;
  --border-hover:#d5d3cf;
  --text:#1a1a1a;
  --text-2:#6b6b6b;
  --text-3:#999;
  --accent:#c96442;
  --accent-light:#d97a58;
  --accent-bg:rgba(201,100,66,0.08);
  --accent-border:rgba(201,100,66,0.2);
  --user-bg:#c96442;
  --user-text:#fff;
  --code-bg:#f5f3ef;
  --code-border:#e5e2dd;
  --green:#188038;
  --green-bg:rgba(24,128,56,0.06);
  --red:#d93025;
  --red-bg:rgba(217,48,37,0.06);
  --shadow:0 1px 3px rgba(0,0,0,0.06);
  --shadow-lg:0 4px 12px rgba(0,0,0,0.08);
  --council-bg:linear-gradient(135deg,#c96442,#d97a58);
  --scrollbar:#d5d3cf;
}
[data-theme="dark"]{
  --bg:#1a1a1a;
  --bg-alt:#2a2a2a;
  --surface:#242424;
  --surface-hover:#2e2e2e;
  --border:#3a3a3a;
  --border-hover:#4a4a4a;
  --text:#e8e6e3;
  --text-2:#999;
  --text-3:#666;
  --accent:#d97a58;
  --accent-light:#e89070;
  --accent-bg:rgba(217,122,88,0.12);
  --accent-border:rgba(217,122,88,0.25);
  --user-bg:#c96442;
  --user-text:#fff;
  --code-bg:#1e1e1e;
  --code-border:#3a3a3a;
  --green:#34d399;
  --green-bg:rgba(52,211,153,0.08);
  --red:#f87171;
  --red-bg:rgba(248,113,113,0.08);
  --shadow:0 1px 3px rgba(0,0,0,0.3);
  --shadow-lg:0 4px 12px rgba(0,0,0,0.4);
  --council-bg:linear-gradient(135deg,#b5573a,#c96442);
  --scrollbar:#4a4a4a;
}

body{
  font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Inter,Roboto,Helvetica,sans-serif;
  background:var(--bg);color:var(--text);height:100dvh;overflow:hidden;
  display:flex;-webkit-font-smoothing:antialiased;line-height:1.6;font-size:14px;
}

/* SIDEBAR */
.sidebar{
  width:260px;background:var(--surface);border-right:1px solid var(--border);
  display:flex;flex-direction:column;flex-shrink:0;transition:transform .25s ease;overflow:hidden;
}
.sb-hdr{padding:16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.sb-hdr .logo{font-size:22px}
.sb-hdr h1{font-size:16px;font-weight:700;color:var(--text)}
.sb-nav{padding:8px;display:flex;flex-direction:column;gap:2px}
.sb-nav button{
  background:none;border:none;text-align:left;padding:8px 12px;border-radius:8px;
  color:var(--text-2);font-size:13px;cursor:pointer;display:flex;align-items:center;gap:8px;transition:all .15s;
}
.sb-nav button:hover{background:var(--surface-hover);color:var(--text)}
.sb-nav button.active{background:var(--accent-bg);color:var(--accent);font-weight:600}
.sb-nav button:disabled{cursor:default;opacity:1}
.sb-nav button:disabled:hover{background:none}
.sb-divider{height:1px;background:var(--border);margin:4px 8px}
.sb-section{padding:12px 16px 4px;font-size:11px;text-transform:uppercase;letter-spacing:.8px;color:var(--text-3);font-weight:600}
.sb-scroll{flex:1;overflow-y:auto;padding-bottom:16px}
.sb-scroll::-webkit-scrollbar{width:4px}
.sb-scroll::-webkit-scrollbar-thumb{background:var(--scrollbar);border-radius:2px}
.sb-footer{
  padding:12px 16px;border-top:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;font-size:11px;color:var(--text-3);
}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;min-width:0}

/* TOP BAR */
.topbar{
  padding:10px 20px;border-bottom:1px solid var(--border);background:var(--surface);
  display:flex;align-items:center;justify-content:space-between;
}
.topbar-l{display:flex;align-items:center;gap:10px}
.topbar-l .menu-btn{
  display:none;background:none;border:1px solid var(--border);border-radius:8px;
  width:32px;height:32px;font-size:16px;cursor:pointer;color:var(--text);
  align-items:center;justify-content:center;
}
.topbar-r{display:flex;align-items:center;gap:8px}
.badge{padding:3px 10px;border-radius:12px;font-size:11px;font-weight:600;letter-spacing:.2px}
.badge-council{background:var(--council-bg);color:#fff}
.badge-skills{background:var(--green-bg);color:var(--green);border:1px solid rgba(24,128,56,0.15)}
.badge-free{background:var(--accent-bg);color:var(--accent);border:1px solid var(--accent-border)}
.theme-toggle{
  width:32px;height:32px;border-radius:8px;background:var(--bg-alt);border:1px solid var(--border);
  color:var(--text-2);cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;transition:all .15s;
}
.theme-toggle:hover{border-color:var(--accent);color:var(--accent)}

/* CHAT */
.chat{flex:1;overflow-y:auto;display:flex;flex-direction:column;scroll-behavior:smooth;background:var(--bg)}
.chat::-webkit-scrollbar{width:6px}
.chat::-webkit-scrollbar-thumb{background:var(--scrollbar);border-radius:3px}

/* WELCOME (Claude-inspired) */
.welcome{
  flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:40px 24px;text-align:center;gap:20px;
}
.welcome-icon{font-size:32px;color:var(--accent)}
.welcome h2{font-size:28px;font-weight:600;color:var(--text);letter-spacing:-.5px}
.welcome h2 span{color:var(--text-2);font-weight:400}
.welcome-sub{font-size:14px;color:var(--text-2);max-width:500px;line-height:1.7}
.actions-grid{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
  gap:8px;max-width:500px;width:100%;margin-top:8px;
}
.action-btn{
  background:var(--surface);border:1px solid var(--border);border-radius:12px;
  padding:14px 16px;cursor:pointer;text-align:left;transition:all .2s;
  display:flex;flex-direction:column;gap:4px;
}
.action-btn:hover{border-color:var(--accent-border);background:var(--surface-hover);transform:translateY(-1px);box-shadow:var(--shadow)}
.action-btn .icon{font-size:18px}
.action-btn .label{font-size:12px;font-weight:600;color:var(--text)}
.action-btn .desc{font-size:11px;color:var(--text-3)}
.model-chips{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;max-width:600px;margin-top:4px}
.model-chip{background:var(--bg-alt);padding:4px 10px;border-radius:8px;font-size:10px;color:var(--text-3);font-weight:500}

/* MESSAGES */
.messages-area{padding:20px;display:flex;flex-direction:column;gap:16px}
.msg{display:flex;gap:10px;animation:msgIn .25s ease}
@keyframes msgIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

.msg-user{justify-content:flex-end}
.msg-user .bubble{
  background:var(--user-bg);color:var(--user-text);border-radius:18px 18px 4px 18px;
  padding:10px 16px;max-width:75%;font-size:14px;line-height:1.6;box-shadow:var(--shadow);
}
.msg-ai .bubble{max-width:85%;padding:2px 0;line-height:1.7;font-size:14px;color:var(--text)}
.msg-ai .bubble p{margin:0 0 8px}
.msg-ai .bubble p:last-child{margin-bottom:0}
.msg-ai .bubble strong,.msg-ai .bubble b{color:var(--accent);font-weight:600}
.msg-ai .bubble code{
  background:var(--code-bg);padding:2px 6px;border-radius:4px;font-size:12.5px;
  font-family:'SF Mono','Cascadia Code','Fira Code',Consolas,monospace;border:1px solid var(--code-border);
}
.msg-ai .bubble pre{
  background:var(--code-bg);padding:12px 16px;border-radius:8px;overflow-x:auto;
  margin:8px 0;font-size:12.5px;line-height:1.5;border:1px solid var(--code-border);
  font-family:'SF Mono','Cascadia Code','Fira Code',Consolas,monospace;
}
.msg-ai .bubble pre code{background:none;border:none;padding:0}
.msg-ai .bubble ul,.msg-ai .bubble ol{padding-left:20px;margin:6px 0}
.msg-ai .bubble li{margin:2px 0}
.msg-ai .bubble a{color:var(--accent);text-decoration:none}
.msg-ai .bubble a:hover{text-decoration:underline}
.msg-ai .bubble h1,.msg-ai .bubble h2,.msg-ai .bubble h3{margin:12px 0 6px;color:var(--text);font-weight:600}
.msg-ai .bubble h1{font-size:18px}.msg-ai .bubble h2{font-size:16px}.msg-ai .bubble h3{font-size:14px}
.msg-ai .bubble blockquote{border-left:3px solid var(--border);padding-left:12px;color:var(--text-2);margin:6px 0}
.msg-ai .bubble hr{border:none;border-top:1px solid var(--border);margin:12px 0}

.council-tag{
  display:inline-flex;align-items:center;gap:5px;
  background:var(--council-bg);color:#fff;padding:3px 12px;
  border-radius:10px;font-size:11px;font-weight:600;margin-bottom:8px;
}
.msg-system .bubble{
  background:var(--bg-alt);border:1px solid var(--border);border-radius:12px;
  padding:10px 14px;font-size:13px;color:var(--text-2);line-height:1.6;
}
.msg-error .bubble{
  background:var(--red-bg);border:1px solid rgba(217,48,37,0.15);border-radius:12px;
  padding:10px 14px;font-size:13px;color:var(--red);
}

/* INPUT */
.input-area{padding:16px 20px;border-top:1px solid var(--border);background:var(--surface)}
.input-row{
  display:flex;gap:10px;align-items:flex-end;
  background:var(--bg);border:1px solid var(--border);border-radius:16px;
  padding:6px 6px 6px 16px;transition:border-color .15s,box-shadow .15s;
}
.input-row:focus-within{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-bg)}
#messageInput{
  flex:1;border:none;background:none;color:var(--text);font-size:14px;
  outline:none;resize:none;font-family:inherit;line-height:1.5;
  min-height:24px;max-height:140px;padding:6px 0;
}
#messageInput::placeholder{color:var(--text-3)}
.send-btn{
  width:36px;height:36px;border-radius:12px;border:none;
  background:var(--accent);color:#fff;cursor:pointer;font-size:16px;
  display:flex;align-items:center;justify-content:center;
  transition:all .15s;flex-shrink:0;
}
.send-btn:hover{background:var(--accent-light);transform:scale(1.05)}
.send-btn:disabled{opacity:.3;cursor:not-allowed;transform:none}
.input-footer{
  display:flex;align-items:center;justify-content:space-between;
  padding:6px 4px 0;font-size:11px;color:var(--text-3);
}

/* OVERLAY + MOBILE */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:99;backdrop-filter:blur(2px)}
.overlay.show{display:block}
@media(max-width:768px){
  .sidebar{position:fixed;left:0;top:0;bottom:0;z-index:100;transform:translateX(-100%);width:280px;box-shadow:var(--shadow-lg)}
  .sidebar.open{transform:translateX(0)}
  .topbar-l .menu-btn{display:flex}
  .msg-user .bubble{max-width:90%}
  .msg-ai .bubble{max-width:95%}
  .welcome h2{font-size:22px}
  .actions-grid{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body>
<div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

<div class="sidebar" id="sidebar">
  <div class="sb-hdr"><span class="logo">🦞</span><h1>Claw AI</h1></div>
  <div class="sb-scroll">
    <div class="sb-nav">
      <button class="active" onclick="goChat()">💬 Chat</button>
      <button onclick="execCmd('/models')">🤖 Models</button>
      <button onclick="execCmd('/skills')">🛠️ Skills</button>
      <button onclick="execCmd('/status')">📊 Status</button>
      <button onclick="execCmd('/help')">❓ Help</button>
    </div>
    <div class="sb-divider"></div>
    <p class="sb-section">Council Models (14)</p>
    <div class="sb-nav" id="modelList"></div>
    <div class="sb-divider"></div>
    <p class="sb-section">Quick Commands</p>
    <div class="sb-nav">
      <button onclick="execCmd('/council')">🏛️ Force Council</button>
      <button onclick="execCmd('/nocouncil')">⚡ Single Model</button>
      <button onclick="execCmd('/clear')">🗑️ Clear Chat</button>
      <button onclick="execCmd('/export')">💾 Export Chat</button>
    </div>
  </div>
  <div class="sb-footer"><span>14 Models · 2 Providers</span><span>v2.0</span></div>
</div>

<div class="main">
  <div class="topbar">
    <div class="topbar-l">
      <button class="menu-btn" onclick="toggleSidebar()">☰</button>
      <span id="statusText" style="font-size:12px;color:var(--text-3)">Loading...</span>
    </div>
    <div class="topbar-r">
      <span class="badge badge-council" id="councilBadge">🏛️ Council</span>
      <span class="badge badge-skills">14 Skills</span>
      <span class="badge badge-free">FREE</span>
      <button class="theme-toggle" onclick="toggleTheme()" title="Toggle theme" id="themeBtn">🌙</button>
    </div>
  </div>

  <div class="chat" id="chat">
    <div class="welcome" id="welcome">
      <div class="welcome-icon">🦞</div>
      <h2>Good evening, <span>sinwa</span></h2>
      <p class="welcome-sub">14 AI models working together for consensus-validated answers. Type <b>/</b> for commands.</p>
      <div class="actions-grid">
        <button class="action-btn" onclick="quickSend('Explain quantum computing simply')">
          <span class="icon">💡</span><span class="label">Learn</span><span class="desc">Ask anything</span>
        </button>
        <button class="action-btn" onclick="quickSend('Write a Python web scraper')">
          <span class="icon">&lt;/&gt;</span><span class="label">Code</span><span class="desc">Generate code</span>
        </button>
        <button class="action-btn" onclick="quickSend('Compare React vs Vue vs Svelte')">
          <span class="icon">✏️</span><span class="label">Analyze</span><span class="desc">Compare things</span>
        </button>
        <button class="action-btn" onclick="execCmd('/skills')">
          <span class="icon">🛠️</span><span class="label">Skills</span><span class="desc">14 specialties</span>
        </button>
      </div>
      <div class="model-chips" id="modelChips"></div>
    </div>
  </div>

  <div class="input-area">
    <div class="input-row">
      <textarea id="messageInput" rows="1" placeholder="Message Claw AI..." onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
      <button class="send-btn" id="sendBtn" onclick="send()">↑</button>
    </div>
    <div class="input-footer">
      <span>Claw AI · 14-Model Council</span>
      <span id="councilLabel">Council mode</span>
    </div>
  </div>
</div>

<script>
/* === STATE === */
const MODELS=[
  {n:'DeepSeek V3',icon:'🥇',tag:'Most Powerful 600B',p:'OR'},
  {n:'Qwen3 80B',icon:'🥈',tag:'Best Balance',p:'OR'},
  {n:'Llama 3.3 70B',icon:'🥉',tag:'Most Stable',p:'OR'},
  {n:'Qwen Coder 32B',icon:'⭐',tag:'Coding King',p:'OR'},
  {n:'DeepSeek R1',icon:'🧮',tag:'Reasoning',p:'OR'},
  {n:'Gemma 3 12B',icon:'⚡',tag:'Fastest',p:'OR'},
  {n:'GPT-4o-mini',icon:'🎯',tag:'Reliable',p:'OR'},
  {n:'Claude 3 Haiku',icon:'🎭',tag:'Natural Chat',p:'OR'},
  {n:'Qwen3 Coder 480B',icon:'🏆',tag:'Best Coder 480B',p:'ALI'},
  {n:'Qwen3.5 397B',icon:'🥇',tag:'Most Powerful',p:'ALI'},
  {n:'Qwen3 Max',icon:'🥈',tag:'Flagship',p:'ALI'},
  {n:'Qwen3 235B',icon:'🧮',tag:'Reasoning 235B',p:'ALI'},
  {n:'Qwen3 Coder+',icon:'⭐',tag:'Coding Expert',p:'ALI'},
  {n:'Qwen Plus',icon:'⚡',tag:'Fast Balanced',p:'ALI'},
];
const SKILLS=[
  {id:'web-dev',d:'React, Vue, Next.js'},{id:'data-science',d:'pandas, numpy, ML'},
  {id:'devops',d:'Docker, K8s, CI/CD'},{id:'security',d:'Audits, scanning'},
  {id:'code-review',d:'Refactoring, patterns'},{id:'testing',d:'Unit, e2e, TDD'},
  {id:'database',d:'SQL, NoSQL'},{id:'api-dev',d:'REST, GraphQL'},
  {id:'mobile-dev',d:'React Native, Flutter'},{id:'ml-ops',d:'ML training'},
  {id:'documentation',d:'README, API docs'},{id:'git-workflow',d:'Branching'},
  {id:'blockchain',d:'Solidity, Web3'},{id:'game-dev',d:'Unity, Godot'},
];
let history=[],councilMode=true;

/* === THEME === */
function initTheme(){
  const t=localStorage.getItem('claw_theme')||'light';
  document.documentElement.setAttribute('data-theme',t);
  document.getElementById('themeBtn').textContent=t==='dark'?'☀️':'🌙';
}
function toggleTheme(){
  const c=document.documentElement.getAttribute('data-theme');
  const n=c==='dark'?'light':'dark';
  document.documentElement.setAttribute('data-theme',n);
  localStorage.setItem('claw_theme',n);
  document.getElementById('themeBtn').textContent=n==='dark'?'☀️':'🌙';
}

/* === INIT === */
function init(){
  initTheme(); renderSidebarModels(); renderModelChips(); loadHistory(); fetchStatus();
  const h=new Date().getHours();
  const g=h<12?'Good morning':h<18?'Good afternoon':'Good evening';
  const el=document.querySelector('.welcome h2');
  if(el) el.innerHTML=g+', <span>sinwa</span>';
}
function renderSidebarModels(){
  document.getElementById('modelList').innerHTML=MODELS.map(m=>
    '<button style="font-size:12px;gap:6px" disabled>'+esc(m.icon)+' <span style="flex:1">'+esc(m.n)+'</span><span style="color:var(--text-3);font-size:10px">'+esc(m.tag)+'</span></button>'
  ).join('');
}
function renderModelChips(){
  document.getElementById('modelChips').innerHTML=MODELS.map(m=>
    '<span class="model-chip">'+esc(m.n)+'</span>'
  ).join('');
}
async function fetchStatus(){
  try{
    const r=await fetch('/api/models');const d=await r.json();
    if(d.council_enabled){
      document.getElementById('statusText').textContent=d.model_count+' models · 2 providers · ready';
      document.getElementById('councilBadge').textContent='🏛️ '+d.model_count+' Models';
    }
  }catch(e){document.getElementById('statusText').textContent='Connecting...'}
}
function loadHistory(){
  try{const s=localStorage.getItem('claw_h');if(s){history=JSON.parse(s);if(history.length){hideWelcome();history.forEach(m=>renderMsg(m))}}}catch(e){}
}
function saveHistory(){try{localStorage.setItem('claw_h',JSON.stringify(history))}catch(e){}}

/* === XSS-SAFE ESCAPE === */
function esc(s){if(!s)return '';const d=document.createElement('span');d.textContent=String(s);return d.innerHTML}

/* === MARKDOWN RENDERER === */
function renderMd(text){
  if(!text)return '';
  let s=String(text);
  s=s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  s=s.replace(/```(\w*)\n?([\s\S]*?)```/g,function(_,lang,code){return '<pre><code>'+code.trim()+'</code></pre>'});
  s=s.replace(/`([^`]+)`/g,'<code>$1</code>');
  s=s.replace(/^### (.+)$/gm,'<h3>$1</h3>');
  s=s.replace(/^## (.+)$/gm,'<h2>$1</h2>');
  s=s.replace(/^# (.+)$/gm,'<h1>$1</h1>');
  s=s.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');
  s=s.replace(/\*(.+?)\*/g,'<em>$1</em>');
  s=s.replace(/\[([^\]]+)\]\(([^)]+)\)/g,'<a href="$2" target="_blank" rel="noopener">$1</a>');
  s=s.replace(/^---$/gm,'<hr>');
  s=s.replace(/^[•\-\*] (.+)$/gm,'<li>$1</li>');
  s=s.replace(/(<li>.*<\/li>\n?)+/g,'<ul>$&</ul>');
  s=s.replace(/^\d+\. (.+)$/gm,'<li>$1</li>');
  s=s.replace(/^&gt; (.+)$/gm,'<blockquote>$1</blockquote>');
  s=s.replace(/\n/g,'<br>');
  s=s.replace(/<pre><code>([\s\S]*?)<\/code><\/pre>/g,function(_,c){return '<pre><code>'+c.replace(/<br>/g,'\n')+'</code></pre>'});
  s=s.replace(/<\/(h[1-3]|pre|ul|ol|blockquote|hr)><br>/g,'</$1>');
  s=s.replace(/<br><(h[1-3]|pre|ul|ol|blockquote|hr)/g,'<$1');
  return s;
}

/* === SLASH COMMAND CONTENT (returns pre-built HTML — no double-escaping) === */
function slashContent(cmd){
  switch(cmd){
    case'/help':return{html:
      '<h3>🦞 Claw AI — Commands</h3>'+
      '<p><strong>Core:</strong> /help · /clear · /status · /version</p>'+
      '<p><strong>Council:</strong> /council · /nocouncil · /models</p>'+
      '<p><strong>Skills (14):</strong></p><ul>'+
      SKILLS.map(s=>'<li><strong>/'+esc(s.id)+'</strong> — '+esc(s.d)+'</li>').join('')+
      '</ul><p><strong>Session:</strong> /save · /export · /config · /memory</p>'};
    case'/models':return{html:
      '<h3>🏛️ Council Models (14)</h3>'+
      '<p><strong>OpenRouter (8):</strong></p><ul>'+
      MODELS.filter(m=>m.p==='OR').map(m=>'<li>'+esc(m.icon)+' <strong>'+esc(m.n)+'</strong> — '+esc(m.tag)+'</li>').join('')+
      '</ul><p><strong>Alibaba Cloud (6):</strong></p><ul>'+
      MODELS.filter(m=>m.p==='ALI').map(m=>'<li>'+esc(m.icon)+' <strong>'+esc(m.n)+'</strong> — '+esc(m.tag)+'</li>').join('')+
      '</ul>'};
    case'/skills':return{html:
      '<h3>🛠️ Available Skills (14)</h3><ul>'+
      SKILLS.map(s=>'<li><strong>/'+esc(s.id)+'</strong> — '+esc(s.d)+'</li>').join('')+
      '</ul><p>Usage: <code>/skill-name your request</code></p>'};
    case'/status':return{html:
      '<h3>📊 Status</h3><ul>'+
      '<li><strong>Council:</strong> '+(councilMode?'Active (14 models)':'Disabled')+'</li>'+
      '<li><strong>Providers:</strong> OpenRouter + Alibaba Cloud</li>'+
      '<li><strong>Skills:</strong> 14 loaded</li>'+
      '<li><strong>Cost:</strong> FREE</li>'+
      '<li><strong>Messages:</strong> '+history.length+'</li></ul>'};
    case'/version':return{html:
      '<h3>🦞 Claw AI v2.0</h3><ul>'+
      '<li>14 models (OpenRouter + Alibaba)</li><li>14 skills</li>'+
      '<li>Session persistence</li><li>File upload</li>'+
      '<li>Light/Dark theme</li><li>Mobile responsive</li></ul>'};
    case'/config':return{html:
      '<h3>⚙️ Config</h3><ul>'+
      '<li><strong>Council:</strong> '+(councilMode?'On':'Off')+'</li>'+
      '<li><strong>Models:</strong> 14</li>'+
      '<li><strong>Providers:</strong> 2</li></ul>'};
    case'/memory':{
      const ch=history.reduce((s,m)=>s+(m.content?.length||0),0);
      const tk=Math.round(ch/4),pc=Math.min(100,tk/2000).toFixed(1);
      return{html:
        '<h3>🧠 Context</h3><ul>'+
        '<li><strong>Tokens:</strong> ~'+tk.toLocaleString()+'</li>'+
        '<li><strong>Max:</strong> 200,000</li>'+
        '<li><strong>Usage:</strong> '+pc+'%</li></ul>'};}
    default:return null;
  }
}

/* === MESSAGE RENDERING === */
function hideWelcome(){const w=document.getElementById('welcome');if(w)w.style.display='none'}
function ensureMsgArea(){
  let a=document.getElementById('msgArea');
  if(!a){a=document.createElement('div');a.id='msgArea';a.className='messages-area';document.getElementById('chat').appendChild(a)}
  return a;
}
function renderMsg(m){
  const area=ensureMsgArea(),div=document.createElement('div');
  if(m.role==='user'){
    div.className='msg msg-user';
    div.innerHTML='<div class="bubble">'+esc(m.content)+'</div>';
  }else if(m.role==='ai'){
    div.className='msg msg-ai';
    let inner='';
    if(m.council&&m.consensus) inner+='<div class="council-tag">🏛️ Council Consensus ('+esc(String(m.consensus))+'%)</div>';
    if(m.rawHtml) inner+='<div class="bubble">'+m.rawHtml+'</div>';
    else inner+='<div class="bubble">'+renderMd(m.content)+'</div>';
    div.innerHTML=inner;
  }else if(m.role==='system'){
    div.className='msg msg-system';
    div.innerHTML='<div class="bubble">'+renderMd(m.content)+'</div>';
  }else if(m.role==='error'){
    div.className='msg msg-error';
    div.innerHTML='<div class="bubble">'+renderMd(m.content)+'</div>';
  }
  area.appendChild(div);scrollChat();
}
function scrollChat(){const c=document.getElementById('chat');c.scrollTop=c.scrollHeight}
function addMsg(role,content,opts){
  opts=opts||{};
  const m={role,content,council:opts.council||false,consensus:opts.consensus||0,rawHtml:opts.rawHtml||null};
  history.push(m);renderMsg(m);saveHistory();
}

/* === SEND / COMMANDS === */
function handleKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();send()}}
function autoResize(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,140)+'px'}
function toggleSidebar(){document.getElementById('sidebar').classList.toggle('open');document.getElementById('overlay').classList.toggle('show')}
function goChat(){if(window.innerWidth<768)toggleSidebar();document.getElementById('messageInput').focus()}
function execCmd(cmd){hideWelcome();handleSlashCmd(cmd);if(window.innerWidth<768)toggleSidebar()}
function quickSend(text){document.getElementById('messageInput').value=text;send()}

function send(){
  const inp=document.getElementById('messageInput'),text=inp.value.trim();
  if(!text)return;
  inp.value='';inp.style.height='auto';hideWelcome();
  if(text.startsWith('/')){handleSlashCmd(text);return}
  addMsg('user',text);callAPI(text);
}
function handleSlashCmd(text){
  const parts=text.split(' '),cmd=parts[0].toLowerCase(),arg=parts.slice(1).join(' ').trim();
  if(cmd==='/council'){
    if(arg){addMsg('user',text);callAPI(arg,true);return}
    councilMode=true;document.getElementById('councilLabel').textContent='Council mode';
    addMsg('system','🏛️ Council enabled — 14 models will collaborate');return;
  }
  if(cmd==='/nocouncil'){
    if(arg){addMsg('user',text);callAPI(arg,false);return}
    councilMode=false;document.getElementById('councilLabel').textContent='Single model';
    addMsg('system','⚡ Council disabled — single model mode');return;
  }
  if(cmd==='/clear'){
    history=[];saveHistory();
    const chat=document.getElementById('chat');chat.innerHTML='';
    const w=document.createElement('div');w.className='welcome';w.id='welcome';w.style.display='flex';
    w.innerHTML='<div class="welcome-icon">🦞</div><h2>Chat cleared</h2><p class="welcome-sub">Start a new conversation</p>';
    chat.appendChild(w);return;
  }
  if(cmd==='/save'){saveHistory();addMsg('system','✅ Session saved');return}
  if(cmd==='/export'){
    let md='# Claw AI Chat Export\n\n';
    history.forEach(m=>md+='## '+m.role+'\n'+(m.content||'')+'\n\n');
    const b=new Blob([md],{type:'text/markdown'}),u=URL.createObjectURL(b);
    const a=document.createElement('a');a.href=u;a.download='claw-'+Date.now()+'.md';a.click();
    URL.revokeObjectURL(u);addMsg('system','✅ Exported as markdown');return;
  }
  const matchedSkill=SKILLS.find(s=>'/'+s.id===cmd);
  if(matchedSkill){
    if(arg){addMsg('user',text);callAPI('Using '+cmd.slice(1)+' skill: '+arg);return}
    addMsg('ai','',{rawHtml:'<h3>🛠️ '+esc(matchedSkill.id)+'</h3><p>'+esc(matchedSkill.d)+'</p><p>Usage: <code>'+esc(cmd)+' your request</code></p>'});
    return;
  }
  const sc=slashContent(cmd);
  if(sc){addMsg('ai','',{rawHtml:sc.html});return}
  addMsg('error','❌ Unknown command: '+esc(cmd)+'. Type /help for available commands.');
}

/* === API === */
async function callAPI(text,useCouncil){
  const btn=document.getElementById('sendBtn');btn.disabled=true;
  const area=ensureMsgArea();
  const thinking=document.createElement('div');
  thinking.className='msg msg-ai';
  thinking.innerHTML='<div class="bubble" style="color:var(--text-3)"><span style="display:inline-block;animation:pulse 1.5s ease infinite">●</span> Thinking...</div>';
  area.appendChild(thinking);scrollChat();

  const council=useCouncil!==undefined?useCouncil:councilMode;
  try{
    const url=council?'/api/council':'/api/chat';
    const r=await fetchRetry(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:text})});
    const d=await r.json();thinking.remove();
    if(!r.ok){addMsg('error','❌ '+(d.error||'Server error'))}
    else if(d.council){
      let reply=(d.reply||'').replace(/\[Council Consensus.*?\]\n?/g,'').trim();
      if(!reply){for(const resp of(d.all_responses||[])){if(resp.content?.trim()){reply=resp.content.trim();break}}}
      addMsg('ai',reply||'No response',{council:true,consensus:d.consensus_percentage});
    }else{addMsg('ai',d.reply||'No response')}
  }catch(e){thinking.remove();addMsg('error','❌ Network error: '+esc(e.message))}
  finally{btn.disabled=false;document.getElementById('messageInput').focus()}
}
async function fetchRetry(url,opts,retries){
  retries=retries||3;
  for(let i=0;i<retries;i++){
    try{const r=await fetch(url,opts);if(r.ok||i===retries-1)return r;await new Promise(s=>setTimeout(s,1000*Math.pow(2,i)))}
    catch(e){if(i===retries-1)throw e;await new Promise(s=>setTimeout(s,1000*Math.pow(2,i)))}
  }
}

/* === BOOT === */
document.addEventListener('DOMContentLoaded',init);
</script>
<style>@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}</style>
</body>
</html>
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>Claw AI - Multi-Model Council</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}

/* ── Light Theme (default) ── */
:root, [data-theme="light"] {
  --bg: #f8fafc;
  --surface: #ffffff;
  --surface-alt: #f1f5f9;
  --border: #e2e8f0;
  --border-hover: #cbd5e1;
  --text: #0f172a;
  --text-secondary: #475569;
  --text-dim: #94a3b8;
  --accent: #6366f1;
  --accent-light: #818cf8;
  --accent-bg: #eef2ff;
  --accent-border: #c7d2fe;
  --green: #059669;
  --green-bg: #ecfdf5;
  --green-border: #a7f3d0;
  --red: #dc2626;
  --red-bg: #fef2f2;
  --red-border: #fecaca;
  --blue: #2563eb;
  --blue-bg: #eff6ff;
  --blue-border: #bfdbfe;
  --amber: #d97706;
  --amber-bg: #fffbeb;
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
  --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
  --shadow-lg: 0 4px 14px rgba(0,0,0,0.08);
  --gradient: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a78bfa 100%);
  --user-msg-bg: linear-gradient(135deg, #6366f1, #8b5cf6);
  --user-msg-text: #ffffff;
  --sidebar-bg: var(--surface);
  --input-bg: var(--surface-alt);
  --code-bg: #f1f5f9;
  --scrollbar: #cbd5e1;
  --scrollbar-hover: #94a3b8;
}

/* ── Dark Theme ── */
[data-theme="dark"] {
  --bg: #0f172a;
  --surface: #1e293b;
  --surface-alt: #1a2332;
  --border: #334155;
  --border-hover: #475569;
  --text: #f1f5f9;
  --text-secondary: #cbd5e1;
  --text-dim: #64748b;
  --accent: #818cf8;
  --accent-light: #a5b4fc;
  --accent-bg: rgba(99,102,241,0.15);
  --accent-border: rgba(99,102,241,0.3);
  --green: #34d399;
  --green-bg: rgba(16,185,129,0.1);
  --green-border: rgba(16,185,129,0.3);
  --red: #f87171;
  --red-bg: rgba(239,68,68,0.1);
  --red-border: rgba(239,68,68,0.3);
  --blue: #60a5fa;
  --blue-bg: rgba(59,130,246,0.1);
  --blue-border: rgba(59,130,246,0.3);
  --amber: #fbbf24;
  --amber-bg: rgba(245,158,11,0.1);
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.2);
  --shadow: 0 1px 3px rgba(0,0,0,0.3);
  --shadow-lg: 0 4px 14px rgba(0,0,0,0.4);
  --gradient: linear-gradient(135deg, #4f46e5 0%, #7c3aed 50%, #8b5cf6 100%);
  --user-msg-bg: linear-gradient(135deg, #4f46e5, #7c3aed);
  --user-msg-text: #ffffff;
  --sidebar-bg: #1a2332;
  --input-bg: #1a2332;
  --code-bg: #0f172a;
  --scrollbar: #475569;
  --scrollbar-hover: #64748b;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', Roboto, sans-serif;
  background: var(--bg);
  color: var(--text);
  height: 100dvh;
  overflow: hidden;
  display: flex;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* ── Sidebar ── */
.sidebar {
  width: 280px;
  background: var(--sidebar-bg);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  flex-shrink: 0;
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
.sidebar::-webkit-scrollbar { width: 4px }
.sidebar::-webkit-scrollbar-thumb { background: var(--scrollbar); border-radius: 2px }
.sidebar::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-hover) }

.side-hdr {
  padding: 20px 16px 16px;
  border-bottom: 1px solid var(--border);
  background: var(--gradient);
  color: #fff;
}
.side-hdr h1 { font-size: 18px; display: flex; align-items: center; gap: 8px; font-weight: 700 }
.side-hdr p { font-size: 11px; color: rgba(255,255,255,0.8); margin-top: 4px }

.side-sec {
  padding: 14px 12px;
  border-bottom: 1px solid var(--border);
}
.side-sec h3 {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--text-dim);
  margin-bottom: 10px;
  font-weight: 700;
}

.mdl {
  background: var(--surface-alt);
  padding: 7px 10px;
  border-radius: 8px;
  margin-bottom: 3px;
  font-size: 11.5px;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: background 0.15s;
}
.mdl:hover { background: var(--accent-bg) }
.mdl .r { min-width: 20px; text-align: center; font-size: 13px }
.mdl .n { flex: 1; font-weight: 600; color: var(--text) }
.mdl .u { color: var(--text-dim); font-size: 10px; white-space: nowrap }

.cbtn {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 8px 12px;
  border-radius: 8px;
  margin-bottom: 4px;
  font-size: 11.5px;
  cursor: pointer;
  text-align: left;
  color: var(--text);
  width: 100%;
  transition: all 0.15s;
  display: flex;
  align-items: center;
  gap: 4px;
}
.cbtn:hover { background: var(--accent-bg); border-color: var(--accent-border); transform: translateX(2px) }
.cbtn code { color: var(--accent); font-weight: 700; font-size: 11px; font-family: 'SF Mono', 'Fira Code', monospace }
.cbtn span { color: var(--text-dim); margin-left: 4px; font-size: 10.5px }

.skill-tag {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 5px 11px;
  border-radius: 16px;
  margin: 3px;
  font-size: 10.5px;
  cursor: pointer;
  color: var(--green);
  transition: all 0.15s;
  display: inline-block;
  font-weight: 500;
}
.skill-tag:hover { background: var(--green-bg); border-color: var(--green-border) }

/* ── Main Area ── */
.main { flex: 1; display: flex; flex-direction: column; min-width: 0 }

.top {
  padding: 12px 20px;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  box-shadow: var(--shadow-sm);
}
.top-l { display: flex; align-items: center; gap: 10px; min-width: 0 }
.top-l h2 { font-size: 15px; font-weight: 700 }
.top-l p { font-size: 11.5px; color: var(--text-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis }

.top-r { display: flex; align-items: center; gap: 8px; flex-shrink: 0 }

.badges { display: flex; gap: 6px }
.bdg {
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 10.5px;
  font-weight: 600;
  white-space: nowrap;
  letter-spacing: 0.2px;
}
.bdg-c { background: var(--gradient); color: #fff }
.bdg-s { background: var(--green-bg); color: var(--green); border: 1px solid var(--green-border) }
.bdg-f { background: var(--blue-bg); color: var(--blue); border: 1px solid var(--blue-border) }

.theme-btn {
  width: 34px;
  height: 34px;
  border-radius: 10px;
  background: var(--surface-alt);
  border: 1px solid var(--border);
  color: var(--text-secondary);
  cursor: pointer;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
}
.theme-btn:hover { background: var(--accent-bg); border-color: var(--accent-border); color: var(--accent) }

.menu-btn {
  display: none;
  width: 34px;
  height: 34px;
  background: none;
  border: 1px solid var(--border);
  border-radius: 10px;
  color: var(--text);
  font-size: 18px;
  cursor: pointer;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
}
.menu-btn:hover { background: var(--surface-alt) }

/* ── Chat Area ── */
.chat {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  scroll-behavior: smooth;
  background: var(--bg);
}
.chat::-webkit-scrollbar { width: 6px }
.chat::-webkit-scrollbar-thumb { background: var(--scrollbar); border-radius: 3px }
.chat::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-hover) }

/* ── Welcome Screen ── */
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  text-align: center;
  gap: 16px;
  padding: 24px;
}
.welcome-icon { font-size: 52px; margin-bottom: 4px }
.welcome h2 { font-size: 22px; font-weight: 700 }
.welcome p { font-size: 13.5px; color: var(--text-secondary); max-width: 420px; line-height: 1.7 }

.chips { display: flex; flex-wrap: wrap; gap: 6px; justify-content: center; max-width: 600px }
.chip {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 11px;
  color: var(--accent);
  font-weight: 500;
}

.qbtns { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 8px }
.qb {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 10px 18px;
  border-radius: 20px;
  font-size: 12.5px;
  color: var(--text);
  cursor: pointer;
  transition: all 0.2s;
  font-weight: 500;
  box-shadow: var(--shadow-sm);
}
.qb:hover { border-color: var(--accent-border); background: var(--accent-bg); transform: translateY(-1px); box-shadow: var(--shadow) }

/* ── Messages ── */
.msg { display: flex; gap: 10px; animation: msgIn 0.3s cubic-bezier(0.4, 0, 0.2, 1) }
@keyframes msgIn { from { opacity: 0; transform: translateY(8px) } to { opacity: 1; transform: translateY(0) } }
.msg.u { justify-content: flex-end }
.mc {
  max-width: 82%;
  padding: 14px 18px;
  border-radius: 16px;
  line-height: 1.7;
  font-size: 13.5px;
  white-space: pre-wrap;
  word-wrap: break-word;
}
.msg.a .mc {
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 3px solid var(--accent);
  color: var(--text);
  box-shadow: var(--shadow-sm);
}
.msg.u .mc {
  background: var(--user-msg-bg);
  color: var(--user-msg-text);
  box-shadow: var(--shadow);
}
.msg.s .mc {
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text-secondary);
  font-size: 12.5px;
  line-height: 1.6;
}

.ctag {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: var(--gradient);
  color: #fff;
  padding: 3px 12px;
  border-radius: 10px;
  font-size: 11px;
  font-weight: 600;
  margin-bottom: 8px;
}
.cresp { white-space: pre-wrap; line-height: 1.7; color: var(--text) }
.cresp b { color: var(--accent) }
.cresp code {
  background: var(--code-bg);
  padding: 2px 7px;
  border-radius: 5px;
  font-size: 12px;
  font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  border: 1px solid var(--border);
}
.err {
  background: var(--red-bg);
  border: 1px solid var(--red-border);
  color: var(--red);
  padding: 12px 16px;
  border-radius: 12px;
  font-size: 12.5px;
  margin: 4px 0;
}
.err b { display: block; margin-bottom: 4px }
.retry {
  background: var(--surface-alt);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 5px 14px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 11px;
  margin-top: 8px;
  transition: all 0.15s;
}
.retry:hover { background: var(--accent); color: #fff; border-color: var(--accent) }

/* ── Input Area ── */
.inp {
  padding: 14px 20px;
  border-top: 1px solid var(--border);
  background: var(--surface);
  box-shadow: 0 -1px 4px rgba(0,0,0,0.03);
}
.fprev {
  margin-bottom: 10px;
  padding: 8px 12px;
  background: var(--surface-alt);
  border: 1px solid var(--border);
  border-radius: 10px;
  font-size: 11.5px;
  display: none;
  align-items: center;
  gap: 8px;
  color: var(--text-secondary);
}
.fprev.show { display: flex }
.fprev .rm { cursor: pointer; color: var(--red); font-weight: 700; margin-left: auto; font-size: 14px }
.fprev .rm:hover { opacity: 0.7 }

.irow { display: flex; gap: 8px; align-items: flex-end }
.iwrap { flex: 1 }

#mi {
  width: 100%;
  padding: 11px 16px;
  background: var(--input-bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  color: var(--text);
  font-size: 13.5px;
  outline: none;
  resize: none;
  min-height: 44px;
  max-height: 140px;
  font-family: inherit;
  line-height: 1.5;
  transition: border-color 0.15s, box-shadow 0.15s;
}
#mi:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-bg) }
#mi::placeholder { color: var(--text-dim) }

.send-btn {
  padding: 11px 24px;
  background: var(--gradient);
  color: #fff;
  border: none;
  border-radius: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
  font-size: 13px;
  letter-spacing: 0.2px;
}
.send-btn:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: var(--shadow-lg) }
.send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none }

.attach-btn {
  padding: 10px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  color: var(--text-dim);
  cursor: pointer;
  font-size: 16px;
  transition: all 0.15s;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.attach-btn:hover { border-color: var(--accent-border); color: var(--accent); background: var(--accent-bg) }

/* ── Overlay ── */
.overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 99; backdrop-filter: blur(2px) }
.overlay.show { display: block }

/* ── Mobile ── */
@media (max-width: 768px) {
  .sidebar { position: fixed; left: 0; top: 0; bottom: 0; z-index: 100; transform: translateX(-100%); width: 280px; box-shadow: var(--shadow-lg) }
  .sidebar.open { transform: translateX(0) }
  .menu-btn { display: flex }
  .mc { max-width: 92% }
  .top { padding: 10px 14px }
  .top-l p { display: none }
  .inp { padding: 10px 14px }
  .badges { gap: 4px }
  .bdg { font-size: 9.5px; padding: 3px 8px }
}
</style>
</head>
<body>
<div class="overlay" id="ov" onclick="tSide()"></div>
<div class="sidebar" id="sb">
  <div class="side-hdr">
    <h1>🦞 Claw AI</h1>
    <p>14-Model Council &bull; 2 Providers</p>
  </div>
  <div class="side-sec" id="ms"></div>
  <div class="side-sec">
    <h3>⚡ Commands</h3>
    <button class="cbtn" onclick="sc('/help')"><code>/help</code><span>All commands</span></button>
    <button class="cbtn" onclick="sc('/council')"><code>/council</code><span>Force council</span></button>
    <button class="cbtn" onclick="sc('/nocouncil')"><code>/nocouncil</code><span>Single model</span></button>
    <button class="cbtn" onclick="sc('/models')"><code>/models</code><span>List models</span></button>
    <button class="cbtn" onclick="sc('/skills')"><code>/skills</code><span>List skills</span></button>
    <button class="cbtn" onclick="sc('/clear')"><code>/clear</code><span>Clear chat</span></button>
    <button class="cbtn" onclick="sc('/status')"><code>/status</code><span>Status</span></button>
  </div>
  <div class="side-sec">
    <h3>🛠️ Skills</h3>
    <div id="ss"></div>
  </div>
</div>
<div class="main">
  <div class="top">
    <div class="top-l">
      <button class="menu-btn" onclick="tSide()">☰</button>
      <h2>💬 Chat</h2>
      <p id="ts">Loading...</p>
    </div>
    <div class="top-r">
      <div class="badges">
        <span class="bdg bdg-c" id="bc">🏛️ Council</span>
        <span class="bdg bdg-s">14 Skills</span>
        <span class="bdg bdg-f">FREE</span>
      </div>
      <button class="theme-btn" id="themeToggle" onclick="toggleTheme()" title="Toggle theme">🌙</button>
    </div>
  </div>
  <div class="chat" id="ch">
    <div class="welcome" id="wl">
      <div class="welcome-icon">🦞</div>
      <h2>Welcome to Claw AI</h2>
      <p>14 AI models from OpenRouter &amp; Alibaba Cloud working together for consensus-validated answers</p>
      <div class="chips" id="wc"></div>
      <div class="qbtns">
        <button class="qb" onclick="qs('What is 2+2?')">🧪 Test Council</button>
        <button class="qb" onclick="qs('/skills')">🛠️ Skills</button>
        <button class="qb" onclick="qs('/models')">🤖 Models</button>
        <button class="qb" onclick="sc('/help')">❓ Help</button>
      </div>
    </div>
  </div>
  <div class="inp">
    <div class="fprev" id="fp"><span id="fn"></span><span class="rm" onclick="rf()">✕</span></div>
    <div class="irow">
      <button class="attach-btn" onclick="document.getElementById('fi').click()" title="Attach file">📎</button>
      <input type="file" id="fi" style="display:none" onchange="hf(event)">
      <div class="iwrap"><textarea id="mi" rows="1" placeholder="Ask anything... (/help for commands)" onkeydown="hk(event)" oninput="ar(this)"></textarea></div>
      <button class="send-btn" id="sb2" onclick="sm()">Send</button>
    </div>
  </div>
</div>
<script>
/* ── Theme Toggle ── */
function initTheme() {
  const saved = localStorage.getItem('claw_theme');
  const theme = saved || 'light';
  document.documentElement.setAttribute('data-theme', theme);
  updateThemeIcon(theme);
}
function toggleTheme() {
  const current = document.documentElement.getAttribute('data-theme');
  const next = current === 'dark' ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('claw_theme', next);
  updateThemeIcon(next);
}
function updateThemeIcon(theme) {
  const btn = document.getElementById('themeToggle');
  if (btn) btn.textContent = theme === 'dark' ? '☀️' : '🌙';
}

/* ── Data ── */
const MD = [
  {n:'DeepSeek V3',r:'🥇',u:'Most Powerful 600B',p:'OR'},
  {n:'Qwen3 80B',r:'🥈',u:'Best Balance',p:'OR'},
  {n:'Llama 3.3 70B',r:'🥉',u:'Most Stable',p:'OR'},
  {n:'Qwen Coder 32B',r:'⭐',u:'Coding King',p:'OR'},
  {n:'DeepSeek R1',r:'🧮',u:'Reasoning',p:'OR'},
  {n:'Gemma 3 12B',r:'⚡',u:'Fastest',p:'OR'},
  {n:'GPT-4o-mini',r:'🎯',u:'Reliable',p:'OR'},
  {n:'Claude 3 Haiku',r:'🎭',u:'Natural Chat',p:'OR'},
  {n:'Qwen3 Coder 480B',r:'🏆',u:'Best Coder 480B',p:'ALI'},
  {n:'Qwen3.5 397B',r:'🥇',u:'Most Powerful',p:'ALI'},
  {n:'Qwen3 Max',r:'🥈',u:'Flagship',p:'ALI'},
  {n:'Qwen3 235B',r:'🧮',u:'Reasoning 235B',p:'ALI'},
  {n:'Qwen3 Coder+',r:'⭐',u:'Coding Expert',p:'ALI'},
  {n:'Qwen Plus',r:'⚡',u:'Fast Balanced',p:'ALI'}
];

const SK = [
  {id:'web-dev',d:'React, Vue, Next.js'},{id:'data-science',d:'pandas, numpy, ML'},
  {id:'devops',d:'Docker, K8s, CI/CD'},{id:'security',d:'Audits, scanning'},
  {id:'code-review',d:'Refactoring, patterns'},{id:'testing',d:'Unit, e2e, TDD'},
  {id:'database',d:'SQL, NoSQL'},{id:'api-dev',d:'REST, GraphQL'},
  {id:'mobile-dev',d:'React Native, Flutter'},{id:'ml-ops',d:'ML training'},
  {id:'documentation',d:'README, API docs'},{id:'git-workflow',d:'Branching'},
  {id:'blockchain',d:'Solidity, Web3'},{id:'game-dev',d:'Unity, Godot'}
];

let H = [], CM = true, AF = null;

/* ── Storage ── */
function ss() { try { localStorage.setItem('claw_h', JSON.stringify(H)) } catch(e) {} }
function ls() { try { const s = localStorage.getItem('claw_h'); if (s) { H = JSON.parse(s); return H.length > 0 } } catch(e) {} return false }

/* ── Init ── */
function init() {
  initTheme();
  rM(); rS(); rC();
  if (ls() && H.length) {
    document.getElementById('wl').style.display = 'none';
    H.forEach(m => am(m.role, m.content, m.c, m.p));
  }
  fs();
}

function rM() {
  document.getElementById('ms').innerHTML =
    '<h3>🏛️ Council Models (14)</h3>' +
    MD.map(m => '<div class="mdl"><span class="r">' + m.r + '</span><span class="n">' + esc(m.n) + '</span><span class="u">' + esc(m.u) + '</span></div>').join('');
}
function rS() {
  document.getElementById('ss').innerHTML =
    SK.map(s => '<span class="skill-tag" onclick="sc(\'/' + s.id + '\')">' + esc(s.id) + '</span>').join('');
}
function rC() {
  document.getElementById('wc').innerHTML =
    MD.map(m => '<span class="chip">' + esc(m.n) + '</span>').join('');
}

async function fs() {
  try {
    const r = await fetch('/api/models');
    const d = await r.json();
    if (d.council_enabled) {
      document.getElementById('ts').textContent = d.model_count + ' models \u2022 2 providers';
      document.getElementById('bc').textContent = '\uD83C\uDFDB\uFE0F ' + d.model_count + ' Models';
    }
  } catch(e) {
    document.getElementById('ts').textContent = 'Connecting...';
  }
}

function tSide() {
  document.getElementById('sb').classList.toggle('open');
  document.getElementById('ov').classList.toggle('show');
}
function ar(el) { el.style.height = 'auto'; el.style.height = Math.min(el.scrollHeight, 140) + 'px' }
function hk(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sm() } }
function hf(e) {
  const f = e.target.files[0]; if (!f) return;
  AF = f;
  document.getElementById('fn').textContent = '\uD83D\uDCCE ' + esc(f.name) + ' (' + (f.size / 1024).toFixed(1) + 'KB)';
  document.getElementById('fp').classList.add('show');
}
function rf() { AF = null; document.getElementById('fp').classList.remove('show'); document.getElementById('fi').value = '' }
function sc(t) { document.getElementById('mi').value = t + ' '; document.getElementById('mi').focus(); if (window.innerWidth < 768) tSide() }
function qs(m) { document.getElementById('mi').value = m; sm() }

/* ── XSS-safe text escaping ── */
function esc(s) {
  const el = document.createElement('span');
  el.textContent = s;
  return el.innerHTML;
}

/* ── Send Message ── */
async function sm() {
  const inp = document.getElementById('mi'), t = inp.value.trim();
  if (!t) return;
  inp.value = ''; inp.style.height = 'auto'; rf();
  document.getElementById('wl').style.display = 'none';
  if (t.startsWith('/')) { hc(t); return }
  am('u', t);
  const sb = document.getElementById('sb2');
  sb.disabled = true; sb.textContent = '\u23F3 Thinking...';
  try {
    const url = CM ? '/api/council' : '/api/chat';
    let body = { message: t };
    if (AF) { try { const c = await rft(AF); body.message = t + '\n\n--- File: ' + AF.name + ' ---\n' + c } catch(e) {} }
    const r = await fw(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    const d = await r.json();
    if (!r.ok) {
      ae('\u274C Error: ' + (d.error || 'Unknown error'));
    } else if (d.council) {
      let clean = (d.reply || '').replace(/\[Council Consensus.*?\]\n?/g, '').trim();
      if (!clean) { for (const resp of (d.all_responses || [])) { if (resp.content && resp.content.trim()) { clean = resp.content.trim(); break } } }
      am('a', clean || 'No response', true, d.consensus_percentage);
    } else {
      am('a', d.reply || 'No response');
    }
  } catch(e) {
    console.error(e);
    ae('\u274C Network error. Please check your connection and try again.');
  } finally {
    sb.disabled = false; sb.textContent = 'Send'; ss(); document.getElementById('mi').focus();
  }
}

/* ── Fetch with retry ── */
async function fw(url, opts, retries = 3) {
  for (let i = 0; i < retries; i++) {
    try {
      const r = await fetch(url, opts);
      if (r.ok || i === retries - 1) return r;
      await new Promise(s => setTimeout(s, 1000 * Math.pow(2, i)));
    } catch(e) {
      if (i === retries - 1) throw e;
      await new Promise(s => setTimeout(s, 1000 * Math.pow(2, i)));
    }
  }
}

/* ── Read file as text ── */
function rft(f) {
  return new Promise((res, rej) => {
    if (f.type.startsWith('text/') || f.name.match(/\.(js|py|json|md|html|css|txt|xml|yaml|yml|toml|cfg|ini|log|csv|ts|tsx|jsx|sql|sh|bat|rb|go|rs|java|cpp|c|h|hpp)$/i)) {
      const rd = new FileReader();
      rd.onload = () => res(rd.result);
      rd.onerror = () => rej(new Error('Read failed'));
      rd.readAsText(f);
    } else {
      res('[Binary file: ' + f.name + ', ' + (f.size / 1024).toFixed(1) + 'KB]');
    }
  });
}

/* ── Slash Commands ── */
function hc(t) {
  const p = t.split(' '), cmd = p[0].toLowerCase(), arg = p.slice(1).join(' ').trim();
  document.getElementById('wl').style.display = 'none';
  switch (cmd) {
    case '/help':
      let h = '<b>\uD83E\uDD9E CLAW AI - All Commands</b>\n\n';
      h += '<b>Core:</b> /help /clear /status /version\n\n';
      h += '<b>Council:</b> /council /nocouncil /models\n\n';
      h += '<b>Skills (14):</b>\n';
      SK.forEach(s => h += '  <b>/' + esc(s.id) + '</b> - ' + esc(s.d) + '\n');
      h += '\n<b>Session:</b> /save /export /config /memory';
      am('a', h); break;
    case '/council':
      if (arg) { CM = true; am('u', arg); scm(arg) } else { CM = true; ae('\uD83C\uDFDB\uFE0F Council enabled - 14 models') } break;
    case '/nocouncil':
      if (arg) { CM = false; am('u', arg); ssm(arg) } else { CM = false; ae('\u26A1 Council disabled - single model') } break;
    case '/models':
      let m = '<b>\uD83C\uDFDB\uFE0F Council Models (14)</b>\n\n<b>OpenRouter (8):</b>\n';
      MD.filter(x => x.p === 'OR').forEach(x => m += '  ' + x.r + ' <b>' + esc(x.n) + '</b> - ' + esc(x.u) + '\n');
      m += '\n<b>Alibaba Cloud (6):</b>\n';
      MD.filter(x => x.p === 'ALI').forEach(x => m += '  ' + x.r + ' <b>' + esc(x.n) + '</b> - ' + esc(x.u) + '\n');
      am('a', m); break;
    case '/skills':
      let s = '<b>\uD83D\uDEE0\uFE0F Available Skills (14)</b>\n\n';
      SK.forEach(x => s += '<b>/' + esc(x.id) + '</b> - ' + esc(x.d) + '\n');
      am('a', s); break;
    case '/clear':
      H = []; ss();
      document.getElementById('ch').innerHTML = '<div class="welcome" id="wl" style="display:flex"><div class="welcome-icon">\uD83E\uDD9E</div><h2>Chat cleared</h2><p>Start a new conversation</p></div>';
      break;
    case '/status':
      ae('\uD83D\uDCCA Status\n\u2022 Council: ' + (CM ? 'Active (14 models)' : 'Disabled') + '\n\u2022 Providers: OpenRouter + Alibaba Cloud\n\u2022 Skills: 14 loaded\n\u2022 Cost: FREE\n\u2022 Messages: ' + H.length);
      break;
    case '/version':
      ae('\uD83E\uDD9E Claw AI v2.0\n\u2022 14 models (OpenRouter + Alibaba)\n\u2022 14 skills\n\u2022 Session persistence\n\u2022 File upload\n\u2022 Mobile responsive\n\u2022 Light/Dark theme');
      break;
    case '/save': ss(); ae('\u2705 Session saved to browser'); break;
    case '/export':
      let md = '# Claw AI Chat\n\n';
      H.forEach(m => md += '## ' + m.role + '\n' + m.content + '\n\n');
      const bl = new Blob([md], { type: 'text/markdown' }), ur = URL.createObjectURL(bl), a = document.createElement('a');
      a.href = ur; a.download = 'claw-' + Date.now() + '.md'; a.click();
      URL.revokeObjectURL(ur);
      ae('\u2705 Exported as markdown'); break;
    case '/config':
      ae('\u2699\uFE0F Config\n\u2022 Council: ' + (CM ? 'On' : 'Off') + '\n\u2022 Models: 14\n\u2022 Providers: 2\n\u2022 API: OpenRouter + Alibaba');
      break;
    case '/memory':
      let ch = H.reduce((s, m) => s + (m.content?.length || 0), 0), tk = Math.round(ch / 4), pc = Math.min(100, tk / 2000).toFixed(1);
      ae('\uD83E\uDDE0 Context\n\u2022 Tokens: ~' + tk.toLocaleString() + '\n\u2022 Max: 200,000\n\u2022 Usage: ' + pc + '%');
      break;
    default:
      if (SK.some(x => '/' + x.id === cmd)) {
        if (arg) { am('u', t); scm('Using ' + cmd + ' skill: ' + arg) }
        else { const sk = SK.find(x => '/' + x.id === cmd); ae('\uD83D\uDEE0\uFE0F <b>' + esc(cmd.slice(1)) + '</b> - ' + (sk ? esc(sk.d) : '') + '\n\nUsage: ' + esc(cmd) + ' <action>') }
      } else { ae('\u274C Unknown command. Type /help') }
  }
}

/* ── API calls (council / single) ── */
async function scm(t) {
  const sb = document.getElementById('sb2'); sb.disabled = true; sb.textContent = '\u23F3 Thinking...';
  try {
    const r = await fw('/api/council', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: t }) });
    const d = await r.json();
    if (!r.ok) ae('\u274C ' + (d.error || 'Error'));
    else {
      let c = (d.reply || '').replace(/\[Council Consensus.*?\]\n?/g, '').trim();
      if (!c) { for (const resp of (d.all_responses || [])) { if (resp.content && resp.content.trim()) { c = resp.content.trim(); break } } }
      am('a', c || 'No response', true, d.consensus_percentage);
    }
  } catch(e) { ae('\u274C Network error. Please try again.') }
  finally { sb.disabled = false; sb.textContent = 'Send'; ss() }
}
async function ssm(t) {
  const sb = document.getElementById('sb2'); sb.disabled = true; sb.textContent = '\u23F3 Thinking...';
  try {
    const r = await fw('/api/chat', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: t }) });
    const d = await r.json();
    if (!r.ok) ae('\u274C ' + (d.error || 'Error')); else am('a', d.reply || 'No response');
  } catch(e) { ae('\u274C Network error. Please try again.') }
  finally { sb.disabled = false; sb.textContent = 'Send'; ss() }
}

/* ── Add message / system event to chat ── */
function am(role, content, council, consensus) {
  const ch = document.getElementById('ch'), d = document.createElement('div');
  d.className = 'msg ' + (role === 'u' ? 'u' : role === 'a' ? 'a' : 's');
  let inner = '';
  if (council && consensus) {
    inner += '<div class="ctag">\uD83C\uDFDB\uFE0F Council Consensus (' + esc(String(consensus)) + '%)</div>\n';
  }
  inner += '<div class="cresp">' + fm(content) + '</div>';
  d.innerHTML = '<div class="mc">' + inner + '</div>';
  ch.appendChild(d);
  ch.scrollTop = ch.scrollHeight;
  H.push({ role, content, c: council || false, p: consensus || 0 });
}

function ae(text) {
  const ch = document.getElementById('ch'), d = document.createElement('div');
  d.className = 'msg s';
  d.innerHTML = '<div class="mc" style="white-space:pre-wrap;line-height:1.6">' + fm(text) + '</div>';
  ch.appendChild(d);
  ch.scrollTop = ch.scrollHeight;
  H.push({ role: 's', content: text });
}

/* ── Minimal markdown formatting ── */
function fm(t) {
  if (!t) return '';
  return t
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/\*\*(.+?)\*\*/g, '<b>$1</b>')
    .replace(/\*(.+?)\*/g, '<i>$1</i>')
    .replace(/`(.+?)`/g, '<code>$1</code>')
    .replace(/\n/g, '<br>');
}

document.addEventListener('DOMContentLoaded', init);
</script>
</body>
</html>
